{
  "buildCommand": "pnpm build:client",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/manus-storage/(.*)", "destination": "/api/manus-storage/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
